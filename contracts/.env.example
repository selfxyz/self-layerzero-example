# LayerZero Cross-Chain Deployment Configuration
# Deploys ProofOfHumanOApp on Celo Mainnet and ProofOfHumanReceiver on Base Mainnet

# Required Configuration
PRIVATE_KEY=0xyour_private_key_with_0x_prefix
VERIFICATION_CONFIG_ID=0xc52f992ebee4435b00b65d2c74b12435e96359d1ccf408041528414e6ea687bc
SCOPE_SEED="self-workshop"

# Advanced Configuration (required for Base Mainnet)
DESTINATION_EID=30184                 # Base Mainnet EID (hardcoded default)
BASE_MAINNET_LZ_ENDPOINT_ADDRESS=0x1a44076050125825900e736c501f859c50fE728c

# Advanced Configuration (optional)
PLACEHOLDER_SCOPE=1

# Deployment Automation (optional)
AUTO_SETUP_PEERS=true          # Automatically configure LayerZero peers
AUTO_FUND_SOURCE=false         # Automatically fund source contract
FUND_AMOUNT="0.01"            # Amount in CELO to fund source contract
VERIFY_CONTRACTS=false         # Verify contracts on block explorers

# Block Explorer API Key (optional, for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Network Information (auto-configured, for reference)
# Source Chain: Celo Mainnet (LayerZero EID: 30125)
#   - Hub Address: 0xe57F4773bd9c9d8b6Cd70431117d353298B9f5BF  
#   - LZ Endpoint: 0x1a44076050125825900e736c501f859c50fE728c
#   - RPC: https://forno.celo.org
#
# Destination Chain: Base Mainnet (LayerZero EID: set DESTINATION_EID)
#   - LZ Endpoint: set BASE_MAINNET_LZ_ENDPOINT_ADDRESS
#   - RPC: https://mainnet.base.org
#
# Note: Celo Alfajores testnet is NOT supported by LayerZero V2
